# Kalshi API credentials (required for scraper.py)
KALSHI_API_KEY=your-kalshi-api-key
KALSHI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Residential proxy for stats.nba.com (required on Railway — datacenter IPs get blocked)
# Format: http://user:pass@host:port
# Get one from a residential proxy provider (e.g. Bright Data, Oxylabs, Smartproxy)
SCRAPER_PROXY=http://user:pass@host:port

# API key auth for the odds API (optional — defaults to demo keys in api_keys.json)
# PORT is set automatically by Railway; override only for local dev
PORT=8000

# Stats scraper poll interval in seconds (default: 3600)
STATS_INTERVAL=3600
